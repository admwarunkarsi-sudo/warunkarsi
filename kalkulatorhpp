<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kalkulator HPP — Warunk Arsi</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sage: #4a7c6f;
    --sage-light: #6aab9b;
    --sage-pale: #e8f4f1;
    --sage-faint: #f4faf8;
    --teal: #2d6a5f;
    --cream: #fdfcf8;
    --warm-white: #f9f8f5;
    --stone: #8a9590;
    --stone-light: #c5cec9;
    --stone-faint: #eef0ef;
    --ink: #1e2b28;
    --ink-soft: #3a4a46;
    --gold: #c8a84b;
    --gold-light: #f0e0a8;
    --red-soft: #d64c4c;
    --red-pale: #fdf0f0;
    --shadow-sm: 0 1px 4px rgba(45,106,95,0.08);
    --shadow-md: 0 4px 16px rgba(45,106,95,0.12);
    --shadow-lg: 0 12px 40px rgba(45,106,95,0.16);
    --radius: 16px;
    --radius-sm: 10px;
    --radius-xs: 6px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--cream);
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(135deg, var(--teal) 0%, var(--sage) 60%, var(--sage-light) 100%);
    padding: 2.5rem 1.5rem 3.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
    pointer-events: none;
  }
  header::after {
    content: '';
    position: absolute; bottom: -1px; left: 0; right: 0; height: 40px;
    background: var(--cream);
    border-radius: 40px 40px 0 0;
  }
  .header-badge {
    display: inline-block;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    backdrop-filter: blur(8px);
  }
  header h1 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    color: #fff;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  header h1 em { font-style: italic; color: var(--gold-light); }
  header p {
    color: rgba(255,255,255,0.8);
    font-size: 0.9rem;
    font-weight: 400;
  }

  /* ── LAYOUT ── */
  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  /* ── SECTION CARD ── */
  .card {
    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--stone-faint);
    margin-bottom: 1.25rem;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .card:hover { box-shadow: var(--shadow-md); }
  .card-header {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--stone-faint);
    background: var(--sage-faint);
  }
  .card-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--sage), var(--teal));
    border-radius: var(--radius-xs);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: 0.01em;
  }
  .card-subtitle {
    font-size: 0.76rem;
    color: var(--stone);
    font-weight: 400;
  }
  .card-body { padding: 1.5rem; }

  /* ── FORM ELEMENTS ── */
  .field-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  @media (max-width: 520px) {
    .field-group { grid-template-columns: 1fr; }
    .field-group.four-col { grid-template-columns: 1fr 1fr; }
  }
  .field-group.four-col { grid-template-columns: repeat(4, 1fr); gap: 0.6rem; }
  @media (max-width: 660px) {
    .field-group.four-col { grid-template-columns: 1fr 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  input[type="text"],
  input[type="number"],
  select {
    width: 100%;
    padding: 0.6rem 0.85rem;
    border: 1.5px solid var(--stone-light);
    border-radius: var(--radius-xs);
    font-family: inherit;
    font-size: 0.88rem;
    color: var(--ink);
    background: var(--warm-white);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    appearance: none;
  }
  input:focus, select:focus {
    border-color: var(--sage-light);
    box-shadow: 0 0 0 3px rgba(106,171,155,0.18);
    background: #fff;
  }
  input[readonly] {
    background: var(--sage-faint);
    color: var(--teal);
    font-weight: 600;
    border-color: var(--sage-pale);
    cursor: default;
  }
  .input-prefix {
    position: relative;
  }
  .input-prefix span {
    position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--stone);
    pointer-events: none;
  }
  .input-prefix input { padding-left: 2.2rem; }
  .input-suffix {
    position: relative;
  }
  .input-suffix span {
    position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--stone);
    pointer-events: none;
  }
  .input-suffix input { padding-right: 2.5rem; }

  /* ── INGREDIENT ROW ── */
  .ingredient-list { display: flex; flex-direction: column; gap: 0.85rem; }

  .ingredient-row {
    background: var(--warm-white);
    border: 1.5px solid var(--stone-faint);
    border-radius: var(--radius-sm);
    padding: 1rem;
    position: relative;
    transition: border-color 0.2s;
    animation: slideIn 0.25s ease;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .ingredient-row:hover { border-color: var(--sage-light); }

  .ingredient-row-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.75rem;
  }
  .ingredient-index {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    background: var(--sage-pale);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }
  .btn-remove {
    background: var(--red-pale);
    border: none;
    color: var(--red-soft);
    width: 28px; height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, transform 0.1s;
    line-height: 1;
  }
  .btn-remove:hover { background: #fde0e0; transform: scale(1.1); }

  .biaya-porsi-display {
    margin-top: 0.6rem;
    padding: 0.5rem 0.75rem;
    background: var(--sage-pale);
    border-radius: var(--radius-xs);
    display: flex; justify-content: space-between; align-items: center;
  }
  .biaya-porsi-display .label { font-size: 0.75rem; color: var(--sage); font-weight: 600; }
  .biaya-porsi-display .value { font-size: 0.88rem; color: var(--teal); font-weight: 700; }

  /* ── BUTTONS ── */
  .btn-add {
    width: 100%;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, var(--sage-pale), #dff0eb);
    border: 2px dashed var(--sage-light);
    border-radius: var(--radius-sm);
    color: var(--teal);
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: background 0.2s, transform 0.1s;
    margin-top: 0.75rem;
    letter-spacing: 0.01em;
  }
  .btn-add:hover { background: linear-gradient(135deg, #d4ede7, #c8e8e1); transform: translateY(-1px); }
  .btn-add:active { transform: translateY(0); }

  /* ── PLATFORM PILLS ── */
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }
  @media (max-width: 420px) { .platform-grid { grid-template-columns: 1fr; } }

  .platform-option { display: none; }
  .platform-label {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--stone-light);
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: var(--warm-white);
    transition: all 0.18s;
    user-select: none;
  }
  .platform-label:hover { border-color: var(--sage-light); background: var(--sage-faint); }
  .platform-option:checked + .platform-label {
    border-color: var(--sage);
    background: var(--sage-pale);
    box-shadow: 0 0 0 3px rgba(74,124,111,0.12);
  }
  .platform-emoji { font-size: 1.2rem; }
  .platform-info { flex: 1; }
  .platform-name { font-size: 0.82rem; font-weight: 700; color: var(--ink-soft); }
  .platform-cut { font-size: 0.7rem; color: var(--stone); }
  .platform-option:checked + .platform-label .platform-name { color: var(--teal); }
  .platform-option:checked + .platform-label .platform-cut { color: var(--sage); }
  .platform-check {
    width: 18px; height: 18px;
    border: 2px solid var(--stone-light);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.18s;
    flex-shrink: 0;
  }
  .platform-option:checked + .platform-label .platform-check {
    background: var(--sage);
    border-color: var(--sage);
  }
  .platform-check::after {
    content: '';
    width: 6px; height: 6px;
    background: white;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .platform-option:checked + .platform-label .platform-check::after { opacity: 1; }

  /* ── MARGIN INPUT ── */
  .margin-row {
    display: flex; align-items: center; gap: 1rem;
  }
  .margin-slider-wrap { flex: 1; }
  input[type="range"] {
    width: 100%;
    accent-color: var(--sage);
    height: 4px;
    cursor: pointer;
  }
  .margin-display {
    background: linear-gradient(135deg, var(--sage), var(--teal));
    color: white;
    font-weight: 800;
    font-size: 1.1rem;
    padding: 0.45rem 1rem;
    border-radius: var(--radius-xs);
    min-width: 70px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .margin-input-num {
    width: 80px;
    text-align: center;
    font-weight: 700;
  }

  /* ── RESULTS ── */
  .results-card {
    background: linear-gradient(135deg, var(--teal) 0%, var(--sage) 100%);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .results-card::before {
    content: '₊';
    position: absolute;
    right: -10px; top: -20px;
    font-size: 8rem;
    color: rgba(255,255,255,0.04);
    font-weight: 900;
    line-height: 1;
  }
  .results-title {
    font-family: 'Instrument Serif', serif;
    font-size: 1.2rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  @media (max-width: 480px) { .results-grid { grid-template-columns: 1fr; } }

  .result-item {
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-sm);
    padding: 1rem 1.1rem;
    transition: background 0.2s;
  }
  .result-item:hover { background: rgba(255,255,255,0.18); }
  .result-item.highlight {
    background: rgba(255,255,255,0.22);
    border-color: rgba(255,255,255,0.35);
    grid-column: 1 / -1;
  }
  .result-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.65);
    margin-bottom: 0.35rem;
  }
  .result-value {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .result-item.highlight .result-value { font-size: 1.8rem; color: var(--gold-light); }
  .result-note {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.55);
    margin-top: 0.2rem;
  }

  .profit-item {
    background: rgba(200, 168, 75, 0.2);
    border: 1px solid rgba(200, 168, 75, 0.4);
  }
  .profit-item .result-value { color: var(--gold-light); }

  /* ── FORMULA INFO ── */
  .formula-box {
    background: var(--stone-faint);
    border-left: 3px solid var(--sage-light);
    border-radius: 0 var(--radius-xs) var(--radius-xs) 0;
    padding: 0.75rem 1rem;
    margin-top: 1rem;
    font-size: 0.78rem;
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .formula-box strong { color: var(--teal); }

  /* ── FOOTER ── */
  footer {
    text-align: center;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--stone-faint);
    margin-top: 1rem;
  }
  .footer-brand {
    font-family: 'Instrument Serif', serif;
    font-size: 1.4rem;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }
  .footer-msg {
    font-size: 0.85rem;
    color: var(--stone);
    line-height: 1.6;
  }
  .footer-heart {
    color: var(--red-soft);
    animation: heartbeat 1.4s ease-in-out infinite;
  }
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }
  .footer-divider {
    display: flex; align-items: center; gap: 0.75rem;
    margin: 1rem 0;
    color: var(--stone-light);
    font-size: 0.75rem;
  }
  .footer-divider::before, .footer-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--stone-faint);
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 1.5rem;
    color: var(--stone);
    font-size: 0.82rem;
  }
  .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }

  /* ── TOOLTIP / BADGE ── */
  .info-badge {
    display: inline-flex; align-items: center; justify-content: center;
    width: 16px; height: 16px;
    background: var(--stone-light);
    color: white;
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 700;
    cursor: help;
    margin-left: 0.25rem;
    vertical-align: middle;
  }

  /* ── SCROLL ANIMATION ── */
  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.5s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-badge">🍽️ Warunk Arsi · Business Tools</div>
  <h1>Kalkulator <em>HPP</em> &<br>Harga Jual Otomatis</h1>
  <p>Hitung biaya produksi & rekomendasi harga jual secara real-time</p>
</header>

<div class="container">

  <!-- CARD 1: BAHAN BAKU -->
  <div class="card fade-in">
    <div class="card-header">
      <div class="card-icon">🧂</div>
      <div>
        <div class="card-title">Bahan Baku per Porsi</div>
        <div class="card-subtitle">Tambahkan semua bahan yang digunakan</div>
      </div>
    </div>
    <div class="card-body">
      <div class="ingredient-list" id="ingredientList">
        <!-- rows injected here -->
      </div>
      <div id="emptyState" class="empty-state">
        <div class="empty-icon">🫙</div>
        <div>Belum ada bahan. Klik tombol di bawah untuk mulai!</div>
      </div>
      <button class="btn-add" onclick="addIngredient()">
        ＋ Tambah Bahan
      </button>
    </div>
  </div>

  <!-- CARD 2: BIAYA TAMBAHAN -->
  <div class="card fade-in">
    <div class="card-header">
      <div class="card-icon">📦</div>
      <div>
        <div class="card-title">Biaya Tambahan per Porsi</div>
        <div class="card-subtitle">Kemasan & operasional lainnya</div>
      </div>
    </div>
    <div class="card-body">
      <div class="field-group">
        <div class="field">
          <label>Biaya Kemasan / Packaging</label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="number" id="biayaKemasan" min="0" placeholder="0" oninput="calculate()">
          </div>
        </div>
        <div class="field">
          <label>Biaya Operasional Lain</label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="number" id="biayaOperasional" min="0" placeholder="0" oninput="calculate()">
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CARD 3: MARGIN & PLATFORM -->
  <div class="card fade-in">
    <div class="card-header">
      <div class="card-icon">🎯</div>
      <div>
        <div class="card-title">Target Margin & Platform</div>
        <div class="card-subtitle">Tentukan keuntungan & saluran penjualan</div>
      </div>
    </div>
    <div class="card-body">
      <div class="field" style="margin-bottom:1.25rem">
        <label>Target Margin Keuntungan</label>
        <div class="margin-row" style="margin-top:0.4rem">
          <div class="margin-slider-wrap">
            <input type="range" id="marginSlider" min="0" max="200" value="30" oninput="syncMargin('slider')">
          </div>
          <div class="margin-display" id="marginDisplay">30%</div>
          <input type="number" id="marginInput" class="margin-input-num" min="0" max="500" value="30"
            oninput="syncMargin('input')" style="width:70px">
        </div>
      </div>

      <div class="field">
        <label>Pilihan Platform Penjualan</label>
        <div class="platform-grid" style="margin-top:0.4rem">
          <div>
            <input type="radio" name="platform" id="p0" class="platform-option" value="0" checked onchange="calculate()">
            <label for="p0" class="platform-label">
              <span class="platform-emoji">🏪</span>
              <div class="platform-info">
                <div class="platform-name">Dine-In / Kasir</div>
                <div class="platform-cut">Potongan 0%</div>
              </div>
              <div class="platform-check"></div>
            </label>
          </div>
          <div>
            <input type="radio" name="platform" id="p35" class="platform-option" value="35" onchange="calculate()">
            <label for="p35" class="platform-label">
              <span class="platform-emoji">🟢</span>
              <div class="platform-info">
                <div class="platform-name">GoFood</div>
                <div class="platform-cut">Potongan 35%</div>
              </div>
              <div class="platform-check"></div>
            </label>
          </div>
          <div>
            <input type="radio" name="platform" id="p45" class="platform-option" value="45" onchange="calculate()">
            <label for="p45" class="platform-label">
              <span class="platform-emoji">🟢</span>
              <div class="platform-info">
                <div class="platform-name">GrabFood</div>
                <div class="platform-cut">Potongan 45%</div>
              </div>
              <div class="platform-check"></div>
            </label>
          </div>
          <div>
            <input type="radio" name="platform" id="p50" class="platform-option" value="50" onchange="calculate()">
            <label for="p50" class="platform-label">
              <span class="platform-emoji">🟠</span>
              <div class="platform-info">
                <div class="platform-name">ShopeeFood</div>
                <div class="platform-cut">Potongan 50%</div>
              </div>
              <div class="platform-check"></div>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- RESULTS -->
  <div class="results-card fade-in" id="resultsCard">
    <div class="results-title">📊 Hasil Perhitungan Real-Time</div>
    <div class="results-grid">
      <div class="result-item">
        <div class="result-label">HPP Bahan Baku</div>
        <div class="result-value" id="rHppBahan">Rp 0</div>
        <div class="result-note">Total biaya semua bahan</div>
      </div>
      <div class="result-item">
        <div class="result-label">HPP Total (Keseluruhan)</div>
        <div class="result-value" id="rHppTotal">Rp 0</div>
        <div class="result-note">Bahan + Kemasan + Operasional</div>
      </div>
      <div class="result-item highlight">
        <div class="result-label">🏷️ Harga Jual Minimum (Rekomendasi)</div>
        <div class="result-value" id="rHargaJual">Rp 0</div>
        <div class="result-note" id="rHargaNote">Untuk Dine-In / Kasir dengan margin 30%</div>
      </div>
      <div class="result-item profit-item">
        <div class="result-label">💰 Estimasi Profit Bersih</div>
        <div class="result-value" id="rProfit">Rp 0</div>
        <div class="result-note">Setelah dipotong komisi platform</div>
      </div>
      <div class="result-item">
        <div class="result-label">Margin Aktual</div>
        <div class="result-value" id="rMarginAktual">0%</div>
        <div class="result-note">Dari harga jual rekomendasi</div>
      </div>
    </div>

    <div class="formula-box" style="background:rgba(255,255,255,0.1); border-color:rgba(255,255,255,0.3); color:rgba(255,255,255,0.8)">
      <strong style="color:var(--gold-light)">📐 Rumus:</strong>
      Harga Jual = (HPP Total + (HPP Total × Margin)) ÷ (1 − Potongan Platform)<br>
      Profit Bersih = Harga Jual × (1 − Potongan) − HPP Total
    </div>
  </div>

</div>

<!-- FOOTER -->
<footer>
  <div class="footer-brand">🍜 Warunk Arsi</div>
  <div class="footer-divider">———</div>
  <div class="footer-msg">
    Terimakasih udah mampir dan dukung terus <strong>Warunk Arsi</strong> yaa <span class="footer-heart">❤️</span><br>
    <span style="font-size:0.78rem; color: var(--stone-light)">Semoga bisnis makin lancar & makin cuan!</span>
  </div>
</footer>

<script>
  let ingredientCount = 0;

  function formatRp(val) {
    if (!val || isNaN(val)) return 'Rp 0';
    return 'Rp ' + Math.ceil(val).toLocaleString('id-ID');
  }

  function addIngredient() {
    ingredientCount++;
    const id = Date.now();
    const list = document.getElementById('ingredientList');
    document.getElementById('emptyState').style.display = 'none';

    const row = document.createElement('div');
    row.className = 'ingredient-row';
    row.id = 'row-' + id;
    row.innerHTML = `
      <div class="ingredient-row-header">
        <span class="ingredient-index">Bahan #${ingredientCount}</span>
        <button class="btn-remove" onclick="removeIngredient('row-${id}')" title="Hapus bahan">✕</button>
      </div>
      <div class="field-group four-col">
        <div class="field" style="grid-column: span 2">
          <label>Nama Bahan</label>
          <input type="text" placeholder="Cth: Daging Ayam" oninput="calculate()">
        </div>
        <div class="field">
          <label>Harga Beli</label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="number" class="harga" min="0" placeholder="0" oninput="calcRow(this); calculate()">
          </div>
        </div>
        <div class="field">
          <label>Isi Kemasan</label>
          <div class="input-suffix">
            <span>gr/ml</span>
            <input type="number" class="kapasitas" min="0" placeholder="0" oninput="calcRow(this); calculate()">
          </div>
        </div>
      </div>
      <div class="field-group" style="grid-template-columns: 1fr 1fr;">
        <div class="field">
          <label>Jumlah Digunakan/Porsi</label>
          <div class="input-suffix">
            <span>gr/ml</span>
            <input type="number" class="digunakan" min="0" placeholder="0" oninput="calcRow(this); calculate()">
          </div>
        </div>
        <div class="field">
          <label>Harga per Satuan</label>
          <input type="text" class="per-satuan" readonly placeholder="Otomatis">
        </div>
      </div>
      <div class="biaya-porsi-display">
        <span class="label">💡 Biaya per Porsi</span>
        <span class="value biaya-porsi">Rp 0</span>
      </div>
    `;
    list.appendChild(row);
    calculate();
  }

  function calcRow(el) {
    const row = el.closest('.ingredient-row');
    const harga = parseFloat(row.querySelector('.harga').value) || 0;
    const kapasitas = parseFloat(row.querySelector('.kapasitas').value) || 0;
    const digunakan = parseFloat(row.querySelector('.digunakan').value) || 0;

    const perSatuan = kapasitas > 0 ? harga / kapasitas : 0;
    const biaya = perSatuan * digunakan;

    row.querySelector('.per-satuan').value = perSatuan > 0 ? 'Rp ' + perSatuan.toFixed(2) : '';
    row.querySelector('.biaya-porsi').textContent = formatRp(biaya);
  }

  function removeIngredient(rowId) {
    const row = document.getElementById(rowId);
    if (row) {
      row.style.animation = 'none';
      row.style.opacity = '0';
      row.style.transform = 'translateX(20px)';
      row.style.transition = 'all 0.2s ease';
      setTimeout(() => {
        row.remove();
        checkEmpty();
        calculate();
      }, 200);
    }
  }

  function checkEmpty() {
    const rows = document.querySelectorAll('.ingredient-row');
    document.getElementById('emptyState').style.display = rows.length === 0 ? 'block' : 'none';
  }

  function syncMargin(source) {
    const slider = document.getElementById('marginSlider');
    const input = document.getElementById('marginInput');
    const display = document.getElementById('marginDisplay');

    if (source === 'slider') {
      input.value = slider.value;
    } else {
      let v = Math.min(500, Math.max(0, parseFloat(input.value) || 0));
      input.value = v;
      slider.value = Math.min(200, v);
    }
    display.textContent = (parseFloat(input.value) || 0) + '%';
    calculate();
  }

  function calculate() {
    // HPP Bahan
    let hppBahan = 0;
    document.querySelectorAll('.ingredient-row').forEach(row => {
      const harga = parseFloat(row.querySelector('.harga').value) || 0;
      const kapasitas = parseFloat(row.querySelector('.kapasitas').value) || 0;
      const digunakan = parseFloat(row.querySelector('.digunakan').value) || 0;
      if (kapasitas > 0) {
        hppBahan += (harga / kapasitas) * digunakan;
      }
    });

    const kemasan = parseFloat(document.getElementById('biayaKemasan').value) || 0;
    const operasional = parseFloat(document.getElementById('biayaOperasional').value) || 0;
    const hppTotal = hppBahan + kemasan + operasional;

    const margin = (parseFloat(document.getElementById('marginInput').value) || 0) / 100;
    const platform = document.querySelector('input[name="platform"]:checked');
    const potongan = platform ? parseFloat(platform.value) / 100 : 0;

    // Harga Jual = (HPP Total + HPP Total × Margin) / (1 - Potongan)
    const divisor = 1 - potongan;
    const hargaJual = divisor > 0 ? (hppTotal * (1 + margin)) / divisor : 0;

    // Profit = Harga Jual × (1 - Potongan) - HPP Total
    const profitBersih = hargaJual * divisor - hppTotal;

    // Margin Aktual
    const marginAktual = hppTotal > 0 ? ((profitBersih) / hppTotal) * 100 : 0;

    // Platform name
    const platformNames = { '0': 'Dine-In / Kasir', '35': 'GoFood', '45': 'GrabFood', '50': 'ShopeeFood' };
    const platformKey = platform ? platform.value : '0';
    const platformName = platformNames[platformKey] || 'Dine-In';

    // Update UI
    document.getElementById('rHppBahan').textContent = formatRp(hppBahan);
    document.getElementById('rHppTotal').textContent = formatRp(hppTotal);
    document.getElementById('rHargaJual').textContent = formatRp(hargaJual);
    document.getElementById('rHargaNote').textContent =
      `Untuk ${platformName} dengan margin ${Math.round(margin * 100)}%`;
    document.getElementById('rProfit').textContent = formatRp(profitBersih);
    document.getElementById('rMarginAktual').textContent =
      hppTotal > 0 ? marginAktual.toFixed(1) + '%' : '0%';
  }

  // Init: add 2 rows
  addIngredient();
  addIngredient();
  calculate();
</script>
</body>
</html>
